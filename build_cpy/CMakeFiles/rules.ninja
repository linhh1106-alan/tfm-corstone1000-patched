#############################################
# Rule for linking C static library.

rule C_STATIC_LIBRARY_LINKER__crypto_service_cc312_mbedtls_api_relwithdebinfo
  command = $PRE_LINK && /work/tmp/work/corstone1000_fvp-poky-linux-musl/trusted-firmware-m/1.6.0-r0/recipe-sysroot-native/usr/bin/cmake -E rm -f $TARGET_FILE && /work/tmp/work/corstone1000_fvp-poky-linux-musl/trusted-firmware-m/1.6.0-r0/recipe-sysroot-native/usr/bin/arm-none-eabi-ar qc $TARGET_FILE $LINK_FLAGS $in && /work/tmp/work/corstone1000_fvp-poky-linux-musl/trusted-firmware-m/1.6.0-r0/recipe-sysroot-native/usr/bin/arm-none-eabi-ranlib $TARGET_FILE && $POST_BUILD
