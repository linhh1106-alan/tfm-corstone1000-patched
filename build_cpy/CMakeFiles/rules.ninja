rule C_COMPILER__crypto_service_cc312_mbedtls_api_relwithdebinfo
  depfile = $DEP_FILE
  deps = gcc
  command = /work/tmp/work/corstone1000_fvp-poky-linux-musl/trusted-firmware-m/1.6.0-r0/recipe-sysroot-native/usr/bin/arm-none-eabi-gcc $DEFINES $INCLUDES $FLAGS -MD -MT $out -MF $DEP_FILE -o $out -c $in
